{
    "moduleFileExtensions": ["js", "json", "ts", "mjs"],
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": ".e2e-spec.ts$",
    "extensionsToTreatAsEsm": [".ts"],
    "transform": {
        "^.+\\.ts$": ["ts-jest", {
            "tsconfig": "<rootDir>/tsconfig.e2e.json",
            "useESM": true
        }]
    },
    "transformIgnorePatterns": [
        "node_modules/(?!(better-auth|@better-auth)/)"
    ],
    "moduleNameMapper": {
        "^@/(.*)$": "<rootDir>/../src/$1",
        "^src/(.*)$": "<rootDir>/../src/$1"
    }
}
