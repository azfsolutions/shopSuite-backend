# ============================================================
# 🔐 SHOPSUITE - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================
# IMPORTANTE: Este archivo es un TEMPLATE
# 1. Copia este archivo como .env en el servidor de producción
# 2. Reemplaza TODOS los valores con valores reales
# 3. NUNCA commits el .env real al repositorio
# 4. Usa servicios de secrets en producción (AWS Secrets Manager, etc.)
# ============================================================

# ------------------------------------------------------------
# APP CONFIGURATION
# ------------------------------------------------------------
NODE_ENV=production
PORT=3001

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# - Siempre usa sslmode=require en producción
# - Usa una contraseña fuerte generada aleatoriamente (32+ caracteres)
# - Limita el acceso a la IP del servidor de aplicación
DATABASE_URL=postgresql://shopsuite:REPLACE_WITH_SECURE_PASSWORD@db.example.com:5432/shopsuite_prod?sslmode=require

# ------------------------------------------------------------
# BETTER AUTH
# ------------------------------------------------------------
# Secret: Mínimo 32 caracteres aleatorios
# Genera con: openssl rand -base64 32
# Rotación: Cambiar cada 6-12 meses o si hay sospecha de compromiso
BETTER_AUTH_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING_GENERATED_WITH_OPENSSL
BETTER_AUTH_URL=https://api.shopsuite.com

# ------------------------------------------------------------
# CORS - CROSS-ORIGIN RESOURCE SHARING
# ------------------------------------------------------------
# URL exacta de tu frontend en producción
# NO incluyas trailing slash
# Múltiples orígenes: sepáralos con coma
FRONTEND_URL=https://app.shopsuite.com

# ------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------
# Límites globales por IP
# 100 requests por minuto es razonable para la mayoría de casos
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ------------------------------------------------------------
# SWAGGER DOCUMENTATION
# ------------------------------------------------------------
# En producción, Swagger debería estar deshabilitado
# O protegido con autenticación adicional
ENABLE_SWAGGER=false

# ------------------------------------------------------------
# FILE STORAGE (Cloudinary)
# ------------------------------------------------------------
# Tu URL de Cloudinary para subir imágenes de productos
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ------------------------------------------------------------
# EMAIL SERVICE (Para notificaciones - Fase futura)
# ------------------------------------------------------------
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=YOUR_SENDGRID_API_KEY
# EMAIL_FROM=noreply@shopsuite.com

# ------------------------------------------------------------
# MONITORING (Sentry - Fase futura)
# ------------------------------------------------------------
# SENTRY_DSN=https://xxxx@sentry.io/xxxxx

# ------------------------------------------------------------
# REDIS CACHE (Fase futura)
# ------------------------------------------------------------
# REDIS_URL=redis://username:password@host:6379

# ============================================================
# 🚨 SECURITY CHECKLIST ANTES DE DEPLOY
# ============================================================
# [ ] BETTER_AUTH_SECRET generado con openssl y único para producción
# [ ] DATABASE_URL con SSL habilitado
# [ ] FRONTEND_URL apunta al dominio correcto
# [ ] ENABLE_SWAGGER=false
# [ ] Todos los REPLACE_WITH_* han sido reemplazados
# [ ] El archivo .env NO está en el repositorio
# [ ] El servidor tiene firewall configurado
# [ ] HTTPS está habilitado en el load balancer
# ============================================================
