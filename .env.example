# Environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/shopsuite?schema=public"

# Redis
REDIS_URL=redis://localhost:6380

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-change-in-production
BETTER_AUTH_URL=http://localhost:3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3002

# Email (Resend) — required for email verification
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@shopsuite.com
